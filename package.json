{
  "name": "typemate",
  "version": "0.1.0",
  "private": true,
  "main": "electron/main.js",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "serve": "vue-cli-service serve",
    "build": "vue-cli-service build --mode production",
    "lint": "vue-cli-service lint",
    "electron:build": "ELECTRON_BUILD=true vue-cli-service build --mode production && electron-builder --mac"
  },
  "build": {
    "appId": "com.typemate.app",
    "productName": "TypeMate",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/main.js"
    ],
    "mac": {
      "target": "dmg",
      "icon": "public/img/icons/android-chrome-512x512.png",
      "category": "public.app-category.productivity"
    },
    "dmg": {
      "title": "TypeMate",
      "artifactName": "TypeMate-arm64.dmg"
    }
  },
  "dependencies": {
    "core-js": "^3.8.3",
    "register-service-worker": "^1.7.2",
    "vue": "^2.6.14",
    "vue2-editor": "^2.10.3"
  },
  "devDependencies": {
    "@babel/core": "^7.12.16",
    "@babel/eslint-parser": "^7.12.16",
    "@vue/cli-plugin-babel": "~5.0.0",
    "@vue/cli-plugin-eslint": "~5.0.0",
    "@vue/cli-plugin-pwa": "~5.0.0",
    "@vue/cli-service": "~5.0.0",
    "@vue/eslint-config-standard": "^6.1.0",
    "electron": "^41.4.0",
    "electron-builder": "^26.8.1",
    "eslint": "^7.32.0",
    "eslint-plugin-import": "^2.25.3",
    "eslint-plugin-node": "^11.1.0",
    "eslint-plugin-promise": "^5.1.0",
    "eslint-plugin-vue": "^8.0.3",
    "sass": "^1.32.7",
    "sass-loader": "^12.0.0",
    "vue-template-compiler": "^2.6.14"
  }
}
